# =============================================================================
# ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env files with real values to version control.
# =============================================================================

# =============================================================================
# NODE ENVIRONMENT
# =============================================================================
NODE_ENV=development

# =============================================================================
# VITE FRONTEND VARIABLES (Must be prefixed with VITE_)
# =============================================================================
# API endpoint for the frontend to communicate with backend.
# For local dev via the Vite proxy → Firebase emulator, use the relative path below.
# For staging/production, set this to the full Firebase Hosting URL, e.g.:
#   VITE_API_URL=https://<YOUR-PROJECT>.web.app/api/trpc
VITE_API_URL=/api/trpc

# Hotel identifier sent with every AI chatbot query.
# Must match a hotel document that exists in Firestore.
VITE_HOTEL_ID=<YOUR-HOTEL-ID>

# Firebase configuration (for client-side SDK)
VITE_FIREBASE_API_KEY=<YOUR-FIREBASE-API-KEY>
VITE_FIREBASE_AUTH_DOMAIN=<YOUR-PROJECT>.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=<YOUR-PROJECT-ID>
VITE_FIREBASE_STORAGE_BUCKET=<YOUR-PROJECT>.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=<YOUR-SENDER-ID>
VITE_FIREBASE_APP_ID=<YOUR-APP-ID>

# =============================================================================
# BACKEND / FUNCTIONS VARIABLES
# =============================================================================
# Note: In CI/CD with Workload Identity Federation, the GCP project is
# automatically detected from the authenticated service account.
# You typically don't need to set GCP_PROJECT_ID explicitly.

# For local development with Firebase emulators:
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
# FIRESTORE_EMULATOR_HOST=localhost:8080

# Firebase Functions emulator settings — used by vite.config.ts to build the proxy URL.
# Only needed for local development. Defaults match firebase.json emulator config.
VITE_FUNCTIONS_REGION=us-central1
VITE_FUNCTIONS_EMULATOR_PORT=5001

# =============================================================================
# GEMINI API (Google AI Studio - free tier)
# Get your key at: https://aistudio.google.com/app/apikey
# =============================================================================
GEMINI_API_KEY=<YOUR-GEMINI-API-KEY>

# =============================================================================
# OPTIONAL: Analytics & Monitoring
# =============================================================================
# VITE_ANALYTICS_ID=<YOUR-ANALYTICS-ID>
# SENTRY_DSN=<YOUR-SENTRY-DSN>
